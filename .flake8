[flake8]
max-line-length = 160
exclude =
    # There's no value in checking cache directories
    __pycache__,
    # Migration files are mostly autogenerated, ignore them
    djsuperadmin/migrations,
    example,
    .venv,
    node_modules,

per-file-ignores =
    # imported but unused
    __init__.py: F401,F403

max-complexity = 12
